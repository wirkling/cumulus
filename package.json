{
  "name": "cumulus",
  "version": "0.1.0",
  "private": true,
  "description": "Cumulus — distributed micro data center control plane (Phase 0a prototype)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "dev:api": "pnpm --filter @cumulus/api dev",
    "dev:dashboard": "pnpm --filter @cumulus/dashboard dev",
    "dev:agent": "pnpm --filter @cumulus/node-agent dev",
    "db:migrate": "pnpm --filter @cumulus/db migrate"
  },
  "devDependencies": {
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
