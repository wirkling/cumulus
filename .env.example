# ───────────────────────────────────────────────────────────────────────────
# Cumulus — environment variable reference (Phase 0a)
#
# This file documents EVERY secret/config value and WHERE it belongs.
# Copy the relevant block to the right place. Never commit a real .env.
# ───────────────────────────────────────────────────────────────────────────

# ── API VPS only (apps/api) ──────────────────────────────────────────────────
# The control plane. These NEVER touch the client or Vercel.
PORT=8080
NODE_ENV=production

# Supabase Postgres — direct connection string (used by packages/db migrations
# and the API query layer). Find under Supabase > Project Settings > Database.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# Supabase service_role key — server-side ONLY. Full DB access; never expose.
SUPABASE_URL=https://[REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Secret used to mint + verify per-node agent tokens (HMAC). Generate a long
# random string, e.g. `openssl rand -hex 32`.
AGENT_TOKEN_SECRET=

# Bootstrap token an agent presents to /api/agent/register to be issued its
# own per-node token. Rotate freely; revoking it only blocks NEW registrations.
AGENT_BOOTSTRAP_TOKEN=

# Operator API key — guards /api/operator/* . The dashboard holds this
# server-side only (never NEXT_PUBLIC).
OPERATOR_API_KEY=

# ── Node agent only (apps/node-agent) ────────────────────────────────────────
# Each compute node. Outbound-only; needs the control-plane URL + bootstrap.
CONTROL_PLANE_URL=https://[VPS_IP].sslip.io
AGENT_BOOTSTRAP_TOKEN=
NODE_NAME=
# Optional simulation knobs (exercise merge/timeout/partial logic before HW):
SIM_LATENCY_MS=0
SIM_JITTER_MS=0
SIM_FAILURE_RATE=0

# ── Dashboard (apps/dashboard) — set in Vercel ───────────────────────────────
# Server-side only (used inside Next.js route handlers / server actions):
API_BASE_URL=https://[VPS_IP].sslip.io
OPERATOR_API_KEY=
# NOTHING with the SUPABASE_SERVICE_ROLE_KEY ever goes here.

# ── Provisioning only (infra/terraform) — your laptop ────────────────────────
# Hetzner Cloud API token from a dedicated throwaway project.
HCLOUD_TOKEN=
